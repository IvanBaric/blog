{
    "name": "ivanbaric/blog",
    "description": "Context-based blog, news, event and content posts for Laravel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "ivanbaric/corexis": "dev-main as 1.0.0",
        "ivanbaric/taxonomy": "dev-main",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "IvanBaric\\Blog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IvanBaric\\Blog\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IvanBaric\\Blog\\BlogServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../corexis",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../taxonomy",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
